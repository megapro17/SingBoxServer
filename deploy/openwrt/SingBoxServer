#!/bin/sh /etc/rc.common

# Приоритет запуска (в самом конце, когда сеть уже поднята)
START=99
# Остановка сервиса
STOP=10

USE_PROCD=1

# Путь к твоему бинарнику
PROG=/root/SingBoxServer
# Рабочая папка (важно, чтобы программа видела конфиги рядом)
DIR=/root

start_service() {
    # Проверяем, существует ли файл и можно ли его запустить
    [ -x "$PROG" ] || return 1

    procd_open_instance "main"

    # Команда на запуск
    procd_set_param command "$PROG"

    # Указываем рабочую директорию
    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}

    # stdout и stderr будут перенаправлены в системный лог (logread)
    procd_set_param stdout 1
    procd_set_param stderr 1

    # Ограничение по памяти (опционально, если хочешь подстраховаться)
    # procd_set_param limits core="unlimited"

    procd_close_instance
}

# Добавляем возможность быстро смотреть логи именно этого приложения
service_triggers() {
    procd_add_reload_trigger "singbox-server"
}